<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>HTML5 Iframe Demonstration</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
            background-color: #f2f2f2;
        }

        h1 {
            text-align: center;
        }

        .section {
            margin-bottom: 40px;
            padding: 10px;
        }

        iframe {
            border: 2px solid black;
            border-radius: 8px;
        }
    </style>
</head>
<body>

    <h1>HTML5 Iframe Demonstration</h1>

    <!-- External Webpage -->
    <div class="section">
        <h2>1. Embedded External Webpage (Wikipedia)</h2>
        <iframe 
            src="https://en.wikipedia.org/wiki/India"
            width="100%" 
            height="400"
            title="Wikipedia Page"
            loading="lazy">
        </iframe>
    </div>

    <!-- Google Map -->
    <div class="section">
        <h2>2. Embedded Google Map</h2>
        <iframe
            src="https://www.google.com/maps?q=Delhi&output=embed"
            width="100%"
            height="400"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            title="Google Map">
        </iframe>
    </div>

    <!-- YouTube Video -->
    <div class="section">
        <h2>3. Embedded YouTube Video</h2>
        <iframe 
            width="100%" 
            height="400"
            src="https://www.youtube.com/embed/ysz5S6PUM-U"
            title="YouTube Video"
            allowfullscreen>
        </iframe>
    </div>

</body>
</html>
