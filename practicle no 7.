<!DOCTYPE html>
<html>
<head>
    <title>Tribute Page</title>

    <!-- Internal CSS -->
    <style>
        /* Element Selector */
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
        }

        /* Navigation Bar */
        .navbar {
            background-color: #333;
            overflow: hidden;
        }

        .navbar a {
            float: left;
            color: white;
            padding: 14px 20px;
            text-decoration: none;
        }

        .navbar a:hover {
            background-color: #ddd;
            color: black;
        }

        /* ID Selector */
        #header {
            background-color: #008080;
            color: white;
            text-align: center;
            padding: 30px;
        }

        /* Class Selector */
        .container {
            padding: 20px;
            margin: 20px;
            background-color: white;
            border: 2px solid #ccc;
            border-radius: 10px;
        }

        .center {
            text-align: center;
        }

        .image {
            display: block;
            margin-left: auto;
            margin-right: auto;
            border-radius: 50%;
            border: 3px solid #555;
        }

        .footer {
            text-align: center;
            background-color: #333;
            color: white;
            padding: 10px;
        }
    </style>
</head>

<body>

    <!-- Navigation Bar -->
    <div class="navbar">
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Achievements</a>
        <a href="#">Contact</a>
    </div>

    <!-- Header Section -->
    <div id="header">
        <h1>Dr. A.P.J. Abdul Kalam</h1>
        <p>Missile Man of India</p>
    </div>

    <!-- Main Content -->
    <div class="container">

        <img src="https://upload.wikimedia.org/wikipedia/commons/9/99/A._P._J._Abdul_Kalam.jpg" 
             alt="APJ Abdul Kalam" width="200" class="image">

        <h2 class="center">About</h2>
        <p>
            Dr. A.P.J. Abdul Kalam was an Indian aerospace scientist and the 11th President of India.
            He is known for his contribution to India's missile and nuclear programs.
        </p>

        <h2 class="center">Achievements</h2>
        <ul>
            <li>Developed India's first satellite launch vehicle</li>
            <li>Key role in Pokhran-II nuclear tests</li>
            <li>Awarded Bharat Ratna</li>
            <li>Inspired millions through his books and speeches</li>
        </ul>

    </div>

    <!-- Footer -->
    <div class="footer">
        <p>Created for Web Designing Lab</p>
    </div>

</body>
</html>
